{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Test App",
  "version": "0.1.0",
  "identifier": "com.noxel.propbuilder.player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Test App",
        "width": 390,
        "height": 844,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": { "width": 540, "height": 360 },
        "appPosition": { "x": 140, "y": 170 },
        "applicationFolderPosition": { "x": 400, "y": 170 }
      }
    }
  }
}
